[
  {
    "name": "milestones",
    "type": "base",
    "schema": [
      { "name": "title",                    "type": "text",   "required": true,  "options": { "max": 80 } },
      { "name": "date",                     "type": "text",   "required": true  },
      { "name": "date_precision",           "type": "select", "required": true,  "options": { "values": ["day","month","year"] } },
      { "name": "direction",                "type": "select", "required": true,  "options": { "values": ["past","future"] } },
      { "name": "category",                 "type": "text",   "required": false },
      { "name": "color",                    "type": "text",   "required": false },
      { "name": "note",                     "type": "text",   "required": false, "options": { "max": 500 } },
      { "name": "has_photo",                "type": "bool",   "required": false },
      { "name": "media_type",               "type": "select", "required": false, "options": { "values": ["audio","video"] } },
      { "name": "url",                      "type": "text",   "required": false },
      { "name": "recurrence",               "type": "select", "required": false, "options": { "values": ["annual"] } },
      { "name": "recurrence_id",            "type": "text",   "required": false },
      { "name": "mainTimelineVisibility",   "type": "select", "required": false, "options": { "values": ["inherit","shown","hidden"] } },
      { "name": "photo",                    "type": "file",   "required": false, "options": { "maxSelect": 1, "maxSize": 10485760 } },
      { "name": "media_file",               "type": "file",   "required": false, "options": { "maxSelect": 1, "maxSize": 104857600 } }
    ]
  },
  {
    "name": "chapters",
    "type": "base",
    "schema": [
      { "name": "title",                    "type": "text",   "required": true,  "options": { "max": 80 } },
      { "name": "start",                    "type": "text",   "required": true  },
      { "name": "end",                      "type": "text",   "required": true  },
      { "name": "color",                    "type": "text",   "required": false },
      { "name": "description",              "type": "text",   "required": false, "options": { "max": 300 } },
      { "name": "defaultMemberVisibility",  "type": "select", "required": false, "options": { "values": ["shown","hidden"] } },
      { "name": "parentChapterId",          "type": "text",   "required": false },
      { "name": "milestoneIds",             "type": "json",   "required": false }
    ]
  }
]
